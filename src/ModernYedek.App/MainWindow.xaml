                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="300"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Source="pack://application:,,,/Assets/resurrectsoft-banner.png" Height="92" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top" ToolTip="ResurrectSoft marka görseli."/>
                                        <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                            <TextBlock Text="ResurrectSoft" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Ink}" ToolTip="MYedek uygulamasını geliştiren yazılım markası."/>
                                            <TextBlock Text="© 2026 ResurrectSoft. Tüm hakları saklıdır." FontWeight="SemiBold" Foreground="{StaticResource Ink}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="MYedek yazılımı, arayüzü, lisans sistemi, güncelleme mekanizması ve yedekleme bileşenleri ResurrectSoft tarafından geliştirilmiştir. Yetkisiz kopyalama, dağıtım, tersine mühendislik ve ticari kullanım yasaktır." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" ToolTip="Yedek tamamlandığında e-posta raporu göndermek için kullanılır.">
                            <StackPanel>
                                <TextBlock Text="E-posta raporu" FontSize="18" FontWeight="SemiBold" ToolTip="Yedekleme sonucu ve log özetini mail olarak gönderir."/>
                                <CheckBox x:Name="MailEnabledCheck" Content="E-posta ayarları aktif" Margin="0,14,0,8" ToolTip="Açık olursa mail sunucusu bilgileri kullanılır."/>
                                <CheckBox x:Name="SendLogAfterBackupCheck" Content="Yedekten sonra log raporunu mail gönder" Margin="0,0,0,12" ToolTip="Açık olursa yedekleme tamamlandığında sonuç özeti alıcı adrese gönderilir."/>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Alıcı mail adresi" Foreground="{StaticResource Muted}" ToolTip="Yedek raporunun gönderileceği adres."/>
                                        <TextBox x:Name="MailRecipientBox" ToolTip="Örnek: muhasebe@sirket.com"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Mail başlığı" Foreground="{StaticResource Muted}" ToolTip="Gönderilecek rapor mailinin başlığı."/>
                                        <TextBox x:Name="MailSubjectBox" Text="Yedek Raporu" ToolTip="Örnek: Günlük Yedek Raporu"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Columns="3" Margin="0,12,0,0">
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="SMTP sunucu" Foreground="{StaticResource Muted}" ToolTip="Mail sunucusunun adresi."/>
                                        <TextBox x:Name="MailServerBox" ToolTip="Örnek: smtp.gmail.com"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Port" Foreground="{StaticResource Muted}" ToolTip="SMTP port numarası."/>
                                        <TextBox x:Name="MailPortBox" Text="587" ToolTip="Genellikle 587 veya 465 kullanılır."/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Kullanıcı adı" Foreground="{StaticResource Muted}" ToolTip="SMTP kullanıcı adı."/>
                                        <TextBox x:Name="MailUserNameBox" ToolTip="Mail sunucusu kullanıcı adı."/>
                                    </StackPanel>
                                </UniformGrid>
                                <CheckBox x:Name="MailUseSslCheck" Content="SSL/TLS kullan" Margin="0,12,0,0" ToolTip="Çoğu SMTP sunucusu için açık olmalıdır."/>
                                <TextBlock Text="Mail parolası Güvenlik sayfasındaki şifreli secret alanından kaydedilir." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0" ToolTip="Parola düz metin ayar dosyasına yazılmaz."/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" ToolTip="Yedekleme öncesi ve sonrası SQL Server servis işlemlerini yönetir.">
                            <StackPanel>
                                <TextBlock Text="SQL Server servis kontrolü" FontSize="18" FontWeight="SemiBold" ToolTip="Gerekirse yedekten önce SQL Server servisini durdurur ve bitince tekrar başlatır."/>
                                <CheckBox x:Name="SqlStopBeforeBackupCheck" Content="Yedekten önce SQL Server servisini durdur" Margin="0,14,0,8" ToolTip="Açık olursa yedek başlamadan önce belirtilen Windows servisi durdurulur. Yönetici yetkisi gerekebilir."/>
                                <CheckBox x:Name="SqlRestartAfterBackupCheck" Content="Yedekten sonra servisi tekrar başlat" Margin="0,0,0,12" ToolTip="Açık olursa durdurulan servis yedekten sonra tekrar başlatılır."/>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Servis adı" Foreground="{StaticResource Muted}" ToolTip="Windows servis adı. Varsayılan SQL Server servisi MSSQLSERVER'dır."/>
                                        <TextBox x:Name="SqlServiceNameBox" Text="MSSQLSERVER" ToolTip="Örnek: MSSQLSERVER veya MSSQL$SQLEXPRESS"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Not" Foreground="{StaticResource Muted}"/>
                                        <TextBlock Text="Servisi durdurmak için uygulamanın yönetici yetkisiyle çalışması gerekebilir." Foreground="{StaticResource Muted}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Rectangle x:Name="PatternAccentLayer" Grid.Row="1" IsHitTestVisible="False" Opacity="0.055">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/zippattern.png"
                                TileMode="Tile"
                                Viewport="0,0,190,190"
                                ViewportUnits="Absolute"
                                Stretch="UniformToFill">
                        <ImageBrush.Transform>
                            <TranslateTransform x:Name="ZipPatternAccentBrushTransform"/>
                        </ImageBrush.Transform>
                    </ImageBrush>
                </Rectangle.Fill>
                <Rectangle.Triggers>
                    <EventTrigger RoutedEvent="Rectangle.Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetName="ZipPatternAccentBrushTransform"
                                                 Storyboard.TargetProperty="X"
                                                 From="0"
                                                 To="-190"
                                                 Duration="0:0:42"/>
                                <DoubleAnimation Storyboard.TargetName="ZipPatternAccentBrushTransform"
                                                 Storyboard.TargetProperty="Y"
                                                 From="0"
                                                 To="190"
                                                 Duration="0:0:42"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Rectangle.Triggers>
            </Rectangle>

            <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" ToolTip="Alt durum çubuğu. Son işlem mesajı ve WhatsApp iletişim numarası burada görünür.">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusBarText" Text="Hazır" VerticalAlignment="Center" Foreground="{StaticResource Muted}" TextTrimming="CharacterEllipsis" ToolTip="Son işlem durumu ve kısa bilgilendirme mesajları burada görünür."/>
                    <TextBlock x:Name="LicenseRemainingText" Grid.Column="1" Text="Lisans: yok" VerticalAlignment="Center" Foreground="{StaticResource Ink}" FontWeight="SemiBold" Margin="18,0,0,0" ToolTip="Sahip olunan aktif lisanstan kaç gün kaldığını gösterir."/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0" ToolTip="Geçici test kontrolü. Pattern opaklığını canlı değiştirir; bulduğunuz değeri bana söyleyebilirsiniz.">
                        <TextBlock Text="Pattern" VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                        <Slider x:Name="PatternOpacitySlider"
                                Width="120"
                                Minimum="0"
                                Maximum="1" Value="0.65" SmallChange="0.01"
                                LargeChange="0.05"
                                TickFrequency="0.01"
                                VerticalAlignment="Center"
                                ValueChanged="PatternOpacitySlider_ValueChanged"/>
                        <TextBlock x:Name="PatternOpacityValueText" Text="0.65" Width="38" VerticalAlignment="Center" Foreground="{StaticResource Ink}" FontWeight="SemiBold" Margin="8,0,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <TextBlock Text="WhatsApp iletişim: 05300221838" VerticalAlignment="Center" Foreground="#128C4A" FontWeight="Bold" ToolTip="Lisans veya destek için WhatsApp iletişim numarası."/>
                        <CheckBox x:Name="TooltipsEnabledCheck"
                                  Content="Açıklamalar"
                                  IsChecked="True"
                                  Checked="TooltipsEnabledCheck_Changed"
                                  Unchecked="TooltipsEnabledCheck_Changed"
                                  VerticalAlignment="Center"
                                  Margin="18,0,0,0"
                                  ToolTip="Açıklama kutularını açıp kapatır. Kapalıyken buton ve alan açıklamaları görünmez."/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
