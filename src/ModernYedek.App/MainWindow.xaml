<Window x:Class="ModernYedek.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MYedek - ResurrectSoft" Icon="pack://application:,,,/Assets/myedek.ico" Height="820" Width="1240" MinHeight="720" MinWidth="1100"
        WindowStartupLocation="CenterScreen" WindowStyle="SingleBorderWindow" ResizeMode="CanResizeWithGrip" ShowInTaskbar="True" Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#21172F"/>
        <SolidColorBrush x:Key="Muted" Color="#71647F"/>
        <SolidColorBrush x:Key="Panel" Color="#F6FFFCFF"/>
        <SolidColorBrush x:Key="Line" Color="#E6DDF4"/>
        <SolidColorBrush x:Key="Accent" Color="#6E3FD1"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#25D366"/>
        <SolidColorBrush x:Key="Bronze" Color="#BD813A"/>
        <DropShadowEffect x:Key="SidebarTextOutlineEffect" Color="#000000" ShadowDepth="0" BlurRadius="1.35" Opacity="0.95"/>

        <Style TargetType="ToolTip">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#25D366"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="14,3"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#DCE6F2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
            <Setter Property="ToolTipService.ShowDuration" Value="15000"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"
                                              Effect="{StaticResource SidebarTextOutlineEffect}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#233147"/>
                                <Setter Property="BorderBrush" Value="#334762"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1F7A6D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
            <Setter Property="ToolTipService.ShowDuration" Value="15000"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Background" Value="#F4F7FB"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
        </Style>

        <Style x:Key="DashboardIconStyle" TargetType="Image">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="PageLeadIconStyle" TargetType="Image">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MiniSignalIconStyle" TargetType="Image">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
            <Setter Property="ToolTipService.ShowDuration" Value="15000"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
            <Setter Property="ToolTipService.ShowDuration" Value="15000"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
            <Setter Property="ToolTipService.ShowDuration" Value="15000"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
            <Setter Property="ToolTipService.ShowDuration" Value="15000"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
            <Setter Property="ToolTipService.ShowDuration" Value="15000"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F5FC">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" ToolTip="Sol menü. Uygulamanın farklı ayar ve izleme sayfalarına buradan geçersiniz.">
            <Border.Background>
                <ImageBrush x:Name="SidebarTextureBrush"
                            ImageSource="pack://application:,,,/Assets/premium-sidebar-texture.png"
                            Stretch="UniformToFill"
                            AlignmentX="Right"
                            AlignmentY="Top"
                            Opacity="1"/>
            </Border.Background>
            <DockPanel LastChildFill="True">
                <DockPanel.Background>
                    <SolidColorBrush x:Name="SidebarOverlayBrush" Color="#0F071C" Opacity="0.57"/>
                </DockPanel.Background>
                <StackPanel DockPanel.Dock="Top" Margin="18,20,18,18">
                    <Image Source="pack://application:,,,/Assets/myedek-icon-master.png" Width="54" Height="54" Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,0,8" ToolTip="MYedek uygulama ikonu."/>
                    <TextBlock Text="MYedek" Foreground="White" FontSize="23" FontWeight="Bold" Effect="{StaticResource SidebarTextOutlineEffect}" ToolTip="Uygulamanın ana adı. Bu araç dosya ve klasörlerinizi yedeklemek için kullanılır."/>
                    <TextBlock Text="ResurrectSoft" Foreground="#25D366" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0" ToolTip="MYedek uygulamasını geliştiren yazılım markası."/>
                    <TextBlock Text="ZIP, zamanlama ve bulut" Foreground="#A8B4C7" FontSize="12" Margin="0,5,0,0" ToolTip="Uygulama ZIP yedekleri oluşturabilir, zamanlayabilir ve isterseniz buluta yükleyebilir."/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="14,14,14,20">
                    <TextBlock x:Name="StoragePathText" Foreground="#A8B4C7" FontSize="11" TextWrapping="Wrap" ToolTip="Ayar, log ve şifreli secret dosyalarının bilgisayarda hangi klasörde tutulduğunu gösterir."/>
                </StackPanel>

                <StackPanel>
                    <Button Style="{StaticResource NavButtonStyle}" Content="Dashboard" Tag="Dashboard" Click="Nav_Click" ToolTip="Genel durumu, son yedeği, sıradaki zamanı, disk alanını ve bulut durumunu gösterir."/>
                    <Button Style="{StaticResource NavButtonStyle}" Content="Kaynaklar" Tag="Sources" Click="Nav_Click" ToolTip="Yedeklenecek dosya veya klasörleri buradan seçersiniz."/>
                    <Button Style="{StaticResource NavButtonStyle}" Content="Hedefler" Tag="Targets" Click="Nav_Click" ToolTip="Yedek ZIP dosyalarının hangi klasöre kaydedileceğini buradan ayarlarsınız."/>
                    <Button Style="{StaticResource NavButtonStyle}" Content="Zamanlama" Tag="Schedule" Click="Nav_Click" ToolTip="Yedeklemenin hangi gün ve saatlerde otomatik çalışacağını buradan ayarlarsınız."/>
                    <Button Style="{StaticResource NavButtonStyle}" Content="Bulut" Tag="Cloud" Click="Nav_Click" ToolTip="Google Cloud Storage bağlantısı ve yedekten sonra buluta yükleme ayarları buradadır."/>
                    <Button Style="{StaticResource NavButtonStyle}" Content="Güvenlik" Tag="Security" Click="Nav_Click" ToolTip="Parola ve Google key gibi hassas bilgileri şifreli secret dosyasına kaydetmek için kullanılır."/>
                    <Button Style="{StaticResource NavButtonStyle}" Content="Lisans" Tag="License" Click="Nav_Click" ToolTip="Lisans anahtarınızı etkinleştirmek, doğrulamak veya lisans durumunu görmek için kullanılır."/>
                    <Button Style="{StaticResource NavButtonStyle}" Content="Loglar" Tag="Logs" Click="Nav_Click" ToolTip="Yedekleme sırasında oluşan bilgi, uyarı ve hata kayıtlarını gösterir."/>
                    <Button Style="{StaticResource NavButtonStyle}" Content="Ayarlar" Tag="Settings" Click="Nav_Click" ToolTip="Profil adı, ZIP seçeneği ve eski ini dosyasını içe aktarma ayarları buradadır."/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="136"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <Rectangle x:Name="PatternBackgroundLayer" Grid.Row="1" IsHitTestVisible="False" Opacity="0.18">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/premium-pattern.png"
                                TileMode="Tile"
                                Viewport="0,0,260,260"
                                ViewportUnits="Absolute"
                                Stretch="UniformToFill">
                        <ImageBrush.Transform>
                            <TranslateTransform x:Name="ZipPatternBrushTransform"/>
                        </ImageBrush.Transform>
                    </ImageBrush>
                </Rectangle.Fill>
                <Rectangle.Triggers>
                    <EventTrigger RoutedEvent="Rectangle.Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetName="ZipPatternBrushTransform"
                                                 Storyboard.TargetProperty="X"
                                                 From="0"
                                                 To="260"
                                                 Duration="0:0:30"/>
                                <DoubleAnimation Storyboard.TargetName="ZipPatternBrushTransform"
                                                 Storyboard.TargetProperty="Y"
                                                 From="0"
                                                 To="260"
                                                 Duration="0:0:30"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Rectangle.Triggers>
            </Rectangle>

            <Border Grid.Row="0" BorderBrush="#8E5CF7" BorderThickness="0,0,0,3" ToolTip="Lisans iletişim şeridi. Lisans almak veya mevcut lisansı yükseltmek için WhatsApp numarasını gösterir.">
                <Border.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/premium-header-banner.png" Stretch="Fill"/>
                </Border.Background>
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="78" Height="78" Background="#25D366" BorderBrush="#D9B16C" BorderThickness="2" CornerRadius="39" HorizontalAlignment="Left" VerticalAlignment="Center" ToolTip="WhatsApp üzerinden lisans talep edebileceğinizi gösteren iletişim simgesi.">
                        <TextBlock Text="☎" Foreground="White" FontSize="46" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="WhatsApp iletişim simgesi."/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleText" Text="Dashboard" Visibility="Collapsed"/>
                        <TextBlock x:Name="PageSubtitleText" Text="Yedekleme durumunu ve önemli uyarıları tek ekrandan takip edin." Visibility="Collapsed"/>
                        <TextBlock x:Name="LicenseBannerTitleText" Text="LİSANS GEREKLİ" Foreground="White" FontSize="32" FontWeight="Black" TextWrapping="Wrap" Effect="{StaticResource SidebarTextOutlineEffect}" ToolTip="Lisans yoksa lisans gerektiğini, lisans varsa yükseltme bilgisini gösterir."/>
                        <TextBlock Text="LİSANS İÇİN WHATSAPPTAN BU NUMARADAN LİSANS TALEP EDİNİZ: 05300221838"
                                   Foreground="#D9FFEA"
                                   FontSize="21"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Effect="{StaticResource SidebarTextOutlineEffect}"
                                   ToolTip="Lisans almak için bu WhatsApp numarasından iletişim kurmanız gerekir: 05300221838"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Şimdi Yedekle" Style="{StaticResource PrimaryButtonStyle}" Click="RunBackup_Click" ToolTip="Ayarları kullanarak hemen manuel yedekleme başlatır. Lisans gerekiyorsa önce lisans kontrol edilir."/>
                        <Button Content="Kaydet" Style="{StaticResource SecondaryButtonStyle}" Click="SaveSettings_Click" ToolTip="Ekrandaki tüm ayarları bilgisayara kaydeder. Değişikliklerden sonra bu butona basın."/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="24">
                    <StackPanel x:Name="DashboardPanel">
                        <UniformGrid Columns="4">
                            <Border Style="{StaticResource CardStyle}" ToolTip="Son yedekleme veya uygulama durumunu hızlıca gösterir.">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="pack://application:,,,/Assets/icon-backup-success.png" Style="{StaticResource DashboardIconStyle}" ToolTip="Yedekleme durum ikonu."/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Son Durum" Foreground="{StaticResource Muted}" FontSize="12" ToolTip="Uygulamanın hazır, çalışıyor, hata veya lisans gerekli gibi genel durumunu belirtir."/>
                                        <TextBlock x:Name="DashboardStatusText" Text="Hazır" Foreground="{StaticResource Ink}" FontSize="22" FontWeight="SemiBold" Margin="0,8,0,0" ToolTip="En son bilinen durum burada yazılır."/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" ToolTip="Zamanlama açıksa bir sonraki otomatik yedekleme zamanını gösterir.">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="pack://application:,,,/Assets/icon-schedule-clock.png" Style="{StaticResource DashboardIconStyle}" ToolTip="Zamanlama ikonu."/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Sıradaki Çalışma" Foreground="{StaticResource Muted}" FontSize="12" ToolTip="Otomatik yedeklemenin bir sonraki çalışacağı tarih ve saat."/>
                                        <TextBlock x:Name="NextRunText" Text="-" Foreground="{StaticResource Ink}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap" ToolTip="Zamanlama kapalıysa burada Kapalı veya boş değer görünebilir."/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" ToolTip="Seçili hedef diskteki boş alan bilgisini gösterir.">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="pack://application:,,,/Assets/icon-zip-archive.png" Style="{StaticResource DashboardIconStyle}" ToolTip="ZIP arşiv ikonu."/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Hedef Disk" Foreground="{StaticResource Muted}" FontSize="12" ToolTip="Yedeklerin kaydedileceği hedef diskin alan durumu."/>
                                        <TextBlock x:Name="DiskSpaceText" Text="-" Foreground="{StaticResource Ink}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap" ToolTip="Yedek başlamadan önce hedefte yeterli boş alan olup olmadığını anlamaya yardımcı olur."/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" ToolTip="Google Cloud Storage ayarlarının genel durumunu gösterir.">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="pack://application:,,,/Assets/icon-cloud-upload.png" Style="{StaticResource DashboardIconStyle}" ToolTip="Bulut yükleme ikonu."/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Bulut" Foreground="{StaticResource Muted}" FontSize="12" ToolTip="Bulut yedekleme açık mı, bucket bilgisi var mı gibi kısa durum bilgisi."/>
                                        <TextBlock x:Name="CloudStateText" Text="Kapalı" Foreground="{StaticResource Ink}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" ToolTip="Bulut kapalıysa yerel yedek alınır ama Google Cloud'a yüklenmez."/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </UniformGrid>

                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,14" ToolTip="Son yedekleme dosyasını, hash bilgisini ve son hata özetini gösterir.">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Yedek Özeti" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Ink}" ToolTip="Son yedekleme hakkında kısa özet alanı."/>
                                    <Image Source="pack://application:,,,/Assets/premium-divider.png" Height="10" Stretch="Fill" Opacity="0.72" Margin="0,8,36,6" IsHitTestVisible="False"/>
                                    <TextBlock x:Name="LastArchiveText" Text="Henüz yedek alınmadı." Margin="0,12,0,0" Foreground="{StaticResource Muted}" TextWrapping="Wrap" ToolTip="Son oluşturulan ZIP dosyasının yolu, SHA256 hash değeri ve dosya boyutu burada görünür."/>
                                    <TextBlock x:Name="ErrorSummaryText" Text="Kritik hata yok." Margin="0,8,0,0" Foreground="{StaticResource Muted}" TextWrapping="Wrap" ToolTip="Son işlemde oluşan önemli hata mesajlarının kısa özeti."/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="24,0,0,0">
                                    <Grid Margin="0,0,0,8" ToolTip="Uyari gerektiren yedekleme durumlarini gosterir.">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Source="pack://application:,,,/Assets/icon-backup-warning.png" Style="{StaticResource MiniSignalIconStyle}" ToolTip="Yedekleme uyari ikonu."/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Uyari takibi" Foreground="{StaticResource Ink}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Kismi yedek ve izin sorunlari burada one cikar." Foreground="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,0,0,10" ToolTip="Basarisiz yedekleme ve kritik hata durumlarini gosterir.">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Image Source="pack://application:,,,/Assets/icon-backup-failed.png" Style="{StaticResource MiniSignalIconStyle}" ToolTip="Yedekleme hata ikonu."/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Hata takibi" Foreground="{StaticResource Ink}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Kaynak, hedef ve ZIP hatalari loglarda ayrintilanir." Foreground="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                    <Button Content="Eski kaydedilmiş ayarları içe aktar" Style="{StaticResource SecondaryButtonStyle}" Click="ImportLegacy_Click" ToolTip="Eski yedekaldat.ini dosyasındaki kaynak, hedef ve zamanlama ayarlarını yeni uygulamaya taşır."/>
                                    <Button Content="Logları Yenile" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshLogs_Click" ToolTip="Log listesini dosyadan yeniden okur ve ekrandaki kayıtları günceller."/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="SourcesPanel" Visibility="Collapsed">
                        <Border Style="{StaticResource CardStyle}" ToolTip="Yedeklenecek dosya ve klasörleri burada yönetirsiniz.">
                            <StackPanel>
                                <TextBlock Text="Kaynak klasörler ve dosyalar" FontSize="18" FontWeight="SemiBold" ToolTip="Yedek içine alınacak tüm kaynaklar bu bölümde listelenir."/>
                                <Grid Height="190" Margin="0,12,0,12">
                                    <ListBox x:Name="SourcesList" ToolTip="Yedeklenecek kayıtlı kaynakları gösterir. Silmek için listedeki kaydı seçip Sil butonuna basın."/>
                                    <Image x:Name="SourcesEmptyArt" Source="pack://application:,,,/Assets/empty-sources.png" Stretch="Uniform" Opacity="0.22" IsHitTestVisible="False"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="138"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SourcePathBox" ToolTip="Yedeklenecek klasör veya dosya yolunu buraya yazın ya da Seç butonu ile bulun."/>
                                    <ComboBox x:Name="SourceTypeBox" Grid.Column="1" Margin="8,0,0,0" SelectedIndex="0" ToolTip="Eklediğiniz yolun klasör mü yoksa tek dosya mı olduğunu seçin.">
                                        <ComboBoxItem Content="Klasör" ToolTip="Bir klasör seçerseniz içindeki dosyalar yedeklenir."/>
                                        <ComboBoxItem Content="Dosya" ToolTip="Tek bir dosya seçerseniz yalnızca o dosya yedeklenir."/>
                                    </ComboBox>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                        <Button Content="Seç" Style="{StaticResource SecondaryButtonStyle}" Click="BrowseSource_Click" ToolTip="Windows dosya/klasör seçicisini açar ve kaynak yolunu otomatik doldurur."/>
                                        <Button Content="Ekle" Style="{StaticResource PrimaryButtonStyle}" Click="AddSource_Click" ToolTip="Yol kutusundaki kaynak dosya veya klasörü yedekleme listesine ekler."/>
                                        <Button Content="Sil" Style="{StaticResource SecondaryButtonStyle}" Click="RemoveSource_Click" ToolTip="Listede seçili olan kaynağı yedekleme listesinden kaldırır."/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
