<Window x:Class="ModernYedek.App.AutoCloseMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520" Height="235"
        MinWidth="520" MinHeight="235"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Background="#F8F5FC">
        <Border Background="#FFFEFF"
                BorderBrush="#E6DDF4"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22"
                Margin="14">
            <StackPanel>
                <TextBlock x:Name="TitleText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#21172F"/>
                <TextBlock x:Name="MessageText"
                           Margin="0,12,0,0"
                           Foreground="#71647F"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="CountdownText"
                           Margin="0,12,0,0"
                           Foreground="#71647F"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Tamam"
                            MinWidth="104"
                            Height="34"
                            Margin="4"
                            Click="Ok_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
