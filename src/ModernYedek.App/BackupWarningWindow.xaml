<Window x:Class="ModernYedek.App.BackupWarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yedekleme Uyarisi" Width="500" Height="245"
        MinWidth="500" MinHeight="245"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Background="#F8F5FC">
        <Border Background="#FFFEFF"
                BorderBrush="#E6DDF4"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22"
                Margin="14">
            <StackPanel>
                <TextBlock Text="Yedekleme yaklasiyor"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#21172F"/>
                <TextBlock x:Name="DueText"
                           Margin="0,10,0,0"
                           Foreground="#21172F"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="CountdownText"
                           Margin="0,8,0,0"
                           Foreground="#71647F"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Hazir degilseniz erteleyebilir veya bu yedegi iptal edebilirsiniz."
                           Margin="0,8,0,0"
                           Foreground="#71647F"
                           TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Content="Iptal Et"
                            MinWidth="104"
                            Height="34"
                            Margin="4"
                            Click="Cancel_Click"/>
                    <Button x:Name="SnoozeButton"
                            Content="Ertele"
                            MinWidth="104"
                            Height="34"
                            Margin="4"
                            Click="Snooze_Click"/>
                    <Button Content="Simdi Yedekle"
                            MinWidth="118"
                            Height="34"
                            Margin="4"
                            Click="StartNow_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
